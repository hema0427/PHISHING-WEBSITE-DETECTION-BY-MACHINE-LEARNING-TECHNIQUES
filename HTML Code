<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Phishing Website Detection</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: url("bg.jpg") no-repeat center center fixed;
            background-size: cover;
        }

        header {
            background: linear-gradient(to right, #6dd5ed, #2193b0);
            padding: 20px;
            text-align: center;
            font-size: 26px;
            font-weight: bold;
            color: #000;
        }

        .container {
            width: 400px;
            margin: 100px auto;
            padding: 30px;
            background: linear-gradient(to bottom right, #89f7fe, #66a6ff);
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 0 15px rgba(0,0,0,0.3);
        }

        input, select, button {
            width: 100%;
            padding: 12px;
            margin-top: 15px;
            border-radius: 6px;
            border: none;
            font-size: 14px;
        }

        button {
            background: #136ef8;
            color: white;
            font-size: 16px;
            cursor: pointer;
        }

        button:hover {
            background: #0b54c2;
        }

        #result {
            margin-top: 20px;
            font-size: 18px;
            font-weight: bold;
        }
    </style>
</head>

<body>

<header>Phishing Website Detection</header>

<div class="container">
    <input type="text" id="url" placeholder="Enter your URL">

    <select id="model">
        <option value="rf">Random Forest</option>
        <option value="svm">SVM</option>
        <option value="dt">Decision Tree</option>
    </select>

    <button onclick="checkPhishing()">Check</button>

    <div id="result"></div>
</div>

<script>
function checkPhishing() {
    let url = document.getElementById("url").value;
    let model = document.getElementById("model").value;

    if (url === "") {
        alert("Please enter a URL");
        return;
    }

    fetch("/predict", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            url: url,
            model: model
        })
    })
    .then(response => response.json())
    .then(data => {
        let resultDiv = document.getElementById("result");

        if (data.prediction === "phishing") {
            resultDiv.style.color = "red";
            resultDiv.innerHTML = "⚠️ Phishing Website Detected!";
        } else {
            resultDiv.style.color = "green";
            resultDiv.innerHTML = "✅ Legitimate Website";
        }
    })
    .catch(error => {
        console.error("Error:", error);
    });
}
</script>

</body>
</html>
